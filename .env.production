APP_NAME="Altair"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://altair.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@altair.app"
MAIL_FROM_NAME="Altair"

VITE_APP_NAME="Altair"
